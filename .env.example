# ====================================
# Omni-Stock V1.5 Environment Variables
# ====================================

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-xxx.region.neon.tech/omnistock?sslmode=require"

# Better Auth
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google OAuth (for SSO login via Better Auth)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Google Sheets API (for one-time migration)
GOOGLE_SHEETS_CLIENT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----"
GOOGLE_SHEETS_ID="your-google-sheet-id"

# Google Gemini AI (for AI Prediction Engine)
GOOGLE_GENERATIVE_AI_API_KEY="your-gemini-api-key"
